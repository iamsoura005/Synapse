# Backend Environment Variables

# Runtime Mode
# Set to false in production to use real database connections
DEMO_MODE=true

# Frontend Origins (for CORS)
# List URLs where frontend is deployed, separated by commas
FRONTEND_ORIGINS=http://localhost:3000,http://localhost:19006

# Database
DATABASE_URL=postgresql+asyncpg://synapse:password@localhost:5432/synapse

# Redis Cache
REDIS_URL=redis://localhost:6379/0

# Neo4j Graph Database
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=adminpassword

# Kafka Message Queue
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# AI Models (Google Generative AI)
GEMINI_API_KEY=
GEMINI_FLASH_MODEL=gemini-2.0-flash
GEMINI_PRO_MODEL=gemini-1.5-pro

# Tavily (Search)
TAVILY_API_KEY=

# Auth & Security
JWT_SECRET_KEY=changeme-in-production
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Slack OAuth
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=

# Splitwise
SPLITWISE_API_KEY=

# Encryption
INTEGRATION_ENCRYPTION_KEY=

# Notifications
ONESIGNAL_APP_ID=
ONESIGNAL_REST_API_KEY=
TELEGRAM_BOT_TOKEN=

# Blockchain (Polygon)
POLYGON_RPC_URL=https://polygon-rpc.com
POLYGON_CONTRACT_ADDRESS=
POLYGON_PRIVATE_KEY=
