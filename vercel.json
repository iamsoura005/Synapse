{
  "version": 2,
  "name": "synapse",
  "builds": [
    {
      "src": "frontend/web/package.json",
      "use": "@vercel/next@latest"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "frontend/web/$1"
    }
  ],
  "env": {
    "NEXT_PUBLIC_API_URL": "@synapse_api_url"
  },
  "regions": ["sfo1"],
  "public": false
}
