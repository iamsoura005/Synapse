{
  "name": "synapse-frontend",
  "version": 2,
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "framework": "nextjs",
  "public": false,
  "cleanUrls": true,
  "trailingSlash": false,
  "env": [
    "NEXT_PUBLIC_API_URL"
  ],
  "envPrefix": "NEXT_PUBLIC_",
  "regions": ["sfo1"],
  "functions": {
    "api/**/*.ts": {
      "memory": 1024,
      "maxDuration": 60
    }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    }
  ]
}
